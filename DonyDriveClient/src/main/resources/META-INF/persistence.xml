      <!-- <property name="javax.persistence.jdbc.url" value="jdbc:postgresql://172.17.104.247/ASISTENTE_SANTA"/> -->
      <!-- LOCAL CENTRAL -->
      <property name="javax.persistence.jdbc.url" value="jdbc:postgresql://localhost/donny"/>
      <property name="javax.persistence.jdbc.user" value="postgres"/>
      <property name="javax.persistence.jdbc.password" value="Pj123456"/>
      <property name="eclipselink.ddl-generation" value="create-tables"/>
    </properties>
  </persistence-unit>
</persistence>
