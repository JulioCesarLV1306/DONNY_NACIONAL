# ===============================================================================
# CONFIGURACIÓN DE BASE DE DATOS - SISTEMA DE BÚSQUEDA JUDICIAL
# ===============================================================================
# Este archivo contiene las plantillas de variables de entorno para la conexión
# a la base de datos PostgreSQL refactorizada con auditoría.
# 
# INSTRUCCIONES:
# 1. Copiar este archivo como .env en el mismo directorio
# 2. Reemplazar los valores de ejemplo con las credenciales reales
# 3. Asegurar que .env esté en .gitignore para no exponer credenciales
# ===============================================================================

# Prefijo: gs_ = Global String (configuración global del sistema)

# Host del servidor PostgreSQL
gs_db_host=localhost

# Puerto del servidor PostgreSQL (por defecto: 5432)
gs_db_port=5432

# Nombre de la base de datos refactorizada
gs_db_name=ASISTENTE_SANTA

# Usuario de la base de datos
gs_db_user=ASISTENTESANTA_ADM

# Contraseña del usuario
gs_db_pass=ADMIN7895123$$#

# Usuario de auditoría (usado para rastrear cambios en c_aud_uid)
# Este valor se usará para identificar las operaciones realizadas por la aplicación
gs_audit_user=SYSTEM_APP

# ===============================================================================
# CONFIGURACIONES ADICIONALES (OPCIONAL)
# ===============================================================================

# Driver JDBC de PostgreSQL (normalmente no es necesario cambiar)
gs_db_driver=org.postgresql.Driver

# Pool de conexiones - Tamaño máximo
gs_db_pool_max_size=10

# Pool de conexiones - Tamaño mínimo
gs_db_pool_min_size=2

# Timeout de conexión en segundos
gs_db_connection_timeout=30
